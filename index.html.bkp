<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" /> 
  <title>CloudInfraFlow — Cloud Infrastructure, DevOps & Platform Engineering</title>
  <meta name="description" content="CloudInfraFlow designs, builds, and operates modern cloud infrastructure across AWS, Azure, and GCP. Kubernetes platforms, DevSecOps, CI/CD, SRE, and FinOps — delivered with care." />
  <meta name="theme-color" content="#0b1220" />
  <meta property="og:title" content="CloudInfraFlow — Cloud Infrastructure, DevOps & Platform Engineering">
  <meta property="og:description" content="Kubernetes, CI/CD, Observability, SRE and FinOps across AWS, Azure & GCP.">
  <meta property="og:type" content="website">
  <meta property="og:image" content="assets/img/og-cover.jpg">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 256 256'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' x2='1' y1='0' y2='1'%3E%3Cstop stop-color='%2300d4ff'/%3E%3Cstop offset='1' stop-color='%236a3df2'/%3E%3C/linearGradient%3E%3C/defs%3E%3Cpath fill='url(%23g)' d='M86 190c-25 0-46-17-52-41C14 146 0 129 0 109c0-30 26-55 58-55 7 0 14 1 20 4C90 25 118 6 151 6c44 0 80 34 80 77v3c15 8 25 24 25 42 0 27-22 49-50 49H86z'/%3E%3C/svg%3E" />
  <style>
    :root{
      --bg:#0b1220; --card:#0f172a; --muted:#94a3b8; --text:#e6edf6; --brand1:#00d4ff; --brand2:#6a3df2; --accent:#00ffa9;
      --ring: linear-gradient(135deg,var(--brand1),var(--brand2));
    }
    *{box-sizing:border-box}
    html,body{margin:0;height:100%;scroll-behavior:smooth;font-family:Inter,system-ui,-apple-system,Seg\006f e UI,Roboto,Ubuntu,"Helvetica Neue",Arial}
    body{color:var(--text);background:
      radial-gradient(1200px 600px at 10% -10%, #12203a 0%, transparent 70%),
      radial-gradient(800px 400px at 90% -20%, #1a103a 0%, transparent 60%), var(--bg)}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;height:auto}
    .container{max-width:1200px;margin:auto;padding:0 24px}

    header{position:sticky;top:0;z-index:50;background:rgba(11,18,32,.8);backdrop-filter:blur(8px);border-bottom:1px solid rgba(255,255,255,.05)} 
    .nav{display:flex;align-items:center;justify-content:space-between;padding:14px 0}
    .brand{display:flex;gap:12px;align-items:center}
    .logo{width:40px;height:40px}
    .brand-title{font-weight:700;letter-spacing:.2px}
    nav ul{display:flex;gap:18px;list-style:none;margin:0;padding:0}     
    .btn{padding:10px 16px;border-radius:12px;border:1px solid rgba(255,255,255,.12);transition:.25s;display:inline-flex;gap:8px;align-items:center}
    .btn:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(0,0,0,.25)}
    .btn-primary{background-image:var(--ring);border:0}
    .btn-ghost{background:transparent}
    .mobile-toggle{display:none}

    .hero{position:relative;overflow:hidden}
    .hero .container{display:grid;grid-template-columns:1fr;gap:24px;align-items:center;padding:64px 24px 32px}
    .headline{font-size:clamp(28px,4.2vw,52px);line-height:1.1;margin:0 0 12px}
    .sub{color:var(--muted);font-size:clamp(14px,1.6vw,18px)}
    .cta{margin-top:22px;display:flex;flex-wrap:wrap;gap:12px}

    .grid{display:grid;gap:18px}
    .grid-2{grid-template-columns:repeat(2,1fr)}
    .grid-3{grid-template-columns:repeat(3,1fr)}
    .card{background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.03));border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:18px;position:relative}
    .card h3{margin:8px 0 6px;font-size:18px}
    .card p{color:var(--muted);margin:0}

    section{padding:54px 0}
    .section-title{font-size:24px;margin:0 0 14px}
    .muted{color:var(--muted)}

    .logos{display:flex;gap:12px;flex-wrap:wrap;align-items:center;opacity:.9}
    .logo-badge{padding:8px 12px;border:1px solid rgba(255,255,255,.08);border-radius:999px;font-size:14px;background:rgba(255,255,255,.04)}      

    .price{font-size:28px;font-weight:800}
    .note{font-size:13px;color:var(--muted)}
    footer{border-top:1px solid rgba(255,255,255,.06);padding:28px 0 56px}

    @media (max-width: 900px){
      nav ul{display:none}
      .mobile-toggle{display:flex}
      .grid-2{grid-template-columns:1fr}
      .grid-3{grid-template-columns:1fr}
    }

    .divider{height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.18),transparent);margin:28px 0}
    .blob{position:absolute;inset:-20% auto auto -10%;width:520px;height:520px;background:
      radial-gradient(circle at 30% 30%,var(--brand1),transparent 60%),  
      radial-gradient(circle at 70% 60%,var(--brand2),transparent 55%);opacity:.25;filter:blur(40px);pointer-events:none}

    /* Profile showcase styles (moved to About section at lower part of page) */
    .profile-card{position:relative;border-radius:20px;padding:14px;background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.04));border:1px solid rgba(255,255,255,.10);box-shadow:0 20px 50px rgba(0,0,0,.35);overflow:hidden}
    .avatar-ring{position:relative;border-radius:18px;padding:3px;background:conic-gradient(from 160deg,var(--brand1),var(--brand2),var(--brand1))}
    .avatar{display:block;width:100%;aspect-ratio: 1/1;object-fit:cover;border-radius:15px;filter: contrast(1.08) saturate(1.08) brightness(1.02);transform: translateZ(0)}
    .avatar-overlay{position:absolute;inset:0;background: radial-gradient(80% 60% at 70% 15%, rgba(255,255,255,.06), transparent 60%),linear-gradient(180deg, transparent 60%, rgba(0,0,0,.18));pointer-events:none;border-radius:18px}
    .profile-meta{display:flex;justify-content:space-between;align-items:center;margin-top:12px;font-size:14px;color:var(--muted)}
    .pill{padding:6px 10px;border-radius:999px;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.04)}

    /* New tasteful animations */
    .fade-up{opacity:0;transform:translateY(16px);animation:fadeUp .8s ease forwards}
    @keyframes fadeUp{to{opacity:1;transform:none}}

    /* Horizontal case studies scroller */
    .cases{display:grid;grid-auto-flow:column;grid-auto-columns:85%;gap:16px;overflow-x:auto;scroll-snap-type:x mandatory;padding-bottom:8px}
    .cases .card{scroll-snap-align:start;min-height:180px}
    .cases::-webkit-scrollbar{height:8px}
    .cases::-webkit-scrollbar-thumb{background:rgba(255,255,255,.12);border-radius:99px}

    /* Sticky mobile CTA */
    .sticky-cta{position:sticky;bottom:12px;z-index:40;display:none}
    @media (max-width: 720px){.sticky-cta{display:block}}

    /* FAQ */
    details{background:linear-gradient(180deg,rgba(255,255,255,.05),rgba(255,255,255,.03));border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:12px}
    details+details{margin-top:10px}
    summary{cursor:pointer;font-weight:600}

    /* Contact form */
    label{font-size:14px;display:block}
    input, textarea{margin-top:6px;border-radius:10px;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.02);color:var(--text);padding:10px}
    input::placeholder, textarea::placeholder{color:#9fb0c9}

    /* Back to top */
    .to-top{position:fixed;right:16px;bottom:16px;opacity:.85}
  </style>
</head>
<body>
  <header>
    <div class="container nav">
      <div class="brand">
        <svg class="logo" viewBox="0 0 256 256" aria-label="CloudInfraFlow logo" role="img">
          <defs><linearGradient id="lg" x1="0" x2="1" y1="0" y2="1"><stop stop-color="#00d4ff"/><stop offset="1" stop-color="#6a3df2"/></linearGradient></defs>
          <path fill="url(#lg)" d="M86 190c-25 0-46-17-52-41C14 146 0 129 0 109c0-30 26-55 58-55 7 0 14 1 20 4C90 25 118 6 151 6c44 0 80 34 80 77v3c15 8 25 24 25 42 0 27-22 49-50 49H86z"/>
          <path fill="#00ffa9" opacity=".8" d="M38 112a10 10 0 0 1 10-10h120a10 10 0 0 1 0 20H48a10 10 0 0 1-10-10Zm18 36a10 10 0 0 1 10-10h136a10 10 0 0 1 0 20H66a10 10 0 0 1-10-10Z"/>
        </svg>
        <div><div class="brand-title">CloudInfraFlow</div><div class="muted" style="font-size:12px">Design • Build • Operate</div></div>
      </div>
      <nav aria-label="Primary">
        <ul>
          <li><a href="#services" class="btn btn-ghost">Services</a></li>
          <li><a href="#solutions" class="btn btn-ghost">Solutions</a></li>
          <li><a href="#work" class="btn btn-ghost">Work</a></li>
          <li><a href="#pricing" class="btn btn-ghost">Pricing</a></li>  
          <li><a href="#contact" class="btn btn-primary">Get a Quote</a></li>
        </ul>
      </nav>
      <button class="btn mobile-toggle" aria-label="Toggle navigation" onclick="toggleNav()">☰</button>
    </div>
  </header>

  <main>
    <section class="hero" id="home">
      <div class="blob" aria-hidden="true"></div>
      <div class="container">
        <div>
          <h1 class="headline fade-up">Modern Cloud Infrastructure that <span style="background-image:var(--ring);-webkit-background-clip:text;background-clip:text;color:transparent">flows</span>.</h1>
          <p class="sub fade-up" style="animation-delay:.08s">We help startups and enterprises ship faster with resilient platforms: Kubernetes, Serverless, CI/CD, Observability and FinOps across <strong>AWS</strong>, <strong>Azure</strong> and <strong>GCP</strong>.</p>
          <div class="cta fade-up" style="animation-delay:.16s">
            <a href="#contact" class="btn btn-primary">Free Architecture Review</a>
            <a href="#services" class="btn">Explore Services</a>
          </div>
          <div class="divider"></div>
          <div class="logos" aria-label="Tech stack">
            <span class="logo-badge">AWS</span><span class="logo-badge">Azure</span><span class="logo-badge">GCP</span>
            <span class="logo-badge">Kubernetes</span><span class="logo-badge">Terraform</span><span class="logo-badge">Argo CD</span>
            <span class="logo-badge">Prometheus/Grafana</span><span class="logo-badge">ELK</span>
          </div>
        </div>
      </div>
    </section>

    <section id="services">
      <div class="container">
        <h2 class="section-title">Services</h2>
        <p class="muted">End-to-end platform engineering to move from idea to reliable production.</p>
        <div class="grid grid-3">
          <div class="card"><h3>Cloud Architecture</h3><p>AWS • Azure • GCP reference designs, landing zones, security baselines, and automation.</p></div>
          <div class="card"><h3>Kubernetes Platform</h3><p>EKS/AKS/GKE clusters, GitOps with Argo CD, Helm, autoscaling, service mesh, policies.</p></div>
          <div class="card"><h3>DevSecOps & CI/CD</h3><p>Jenkins/GitHub/GitLab pipelines, quality gates, SAST/DAST, artifact management, releases.</p></div>
          <div class="card"><h3>Observability</h3><p>Prometheus, Grafana, ELK, OpenTelemetry, SLOs, on-call workflows and runbooks.</p></div>     
          <div class="card"><h3>FinOps</h3><p>Cost governance, right-sizing, budgets, tagging, chargeback, automated shutdowns.</p></div>
          <div class="card"><h3>Migrations</h3><p>Rehost/Refactor to containers or serverless with zero-downtime cutovers.</p></div>
        </div>
        <div class="divider"></div>
        <div class="grid grid-3">
          <div class="card"><h3>Security & Compliance</h3><p>WAF, IAM least-privilege, secret management, CIS/NIST/ISO mappings and audits.</p></div>
          <div class="card"><h3>Site Reliability Engineering</h3><p>SLO/SLI design, chaos testing, incident response and postmortems with action items.</p></div>
          <div class="card"><h3>Data Platform Foundations</h3><p>Managed DBs, streaming, lakehouse patterns, backup/restore, DR and RPO/RTO drills.</p></div>
        </div>
      </div>
    </section>

    <section id="solutions">
      <div class="container">
        <h2 class="section-title">Solutions</h2>
        <div class="grid grid-3">
          <div class="card"><h3>Banking-grade Platforms</h3><p>Network isolation, WAF, secrets, policy as code, audit trails, and encryption by default.</p></div>
          <div class="card"><h3>Data & ML Foundations</h3><p>Managed databases, event buses, batch/stream pipelines, feature stores and MLOps.</p></div>
          <div class="card"><h3>Edge & CDN</h3><p>Static sites and APIs accelerated via CloudFront/Cloud CDN and edge security.</p></div>
        </div>
      </div>
    </section>

    <!-- Case studies / Results -->
    <section id="work">
      <div class="container">
        <h2 class="section-title">Recent Work & Results</h2>
        <p class="muted">Real outcomes we've delivered.</p>
        <div class="cases" aria-label="Case studies">
          <article class="card">
            <h3>FinTech on AKS</h3>
            <p class="muted">99.95% SLO achieved, 38% cloud cost reduction with autoscaling & spot strategy. End-to-end GitOps.</p>
          </article>
          <article class="card">
            <h3>E‑commerce Observability</h3>
            <p class="muted">MTTR down from 2h → 18m by integrating OpenTelemetry and SLO burn-rate alerts.</p>
          </article>
          <article class="card">
            <h3>GCP Landing Zone</h3>
            <p class="muted">Org policies, VPC‑SC, automated projects via Terraform; compliant in 3 weeks.</p>
          </article>
          <article class="card">
            <h3>Data Platform Hardening</h3>
            <p class="muted">Zero trust IAM, customer‑managed keys, DR tests passing with RPO 5m / RTO 30m.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section id="process">
      <div class="container">
        <h2 class="section-title">Our Delivery Process</h2>
        <div class="grid grid-2">
          <div class="card"><h3>1) Discover</h3><p class="muted">Architecture review, risks, SLAs and a roadmap you can act on in days—not months.</p></div>
          <div class="card"><h3>2) Design</h3><p class="muted">Reference blueprints, IaC stacks, security controls and runbooks ready for teams.</p></div>
          <div class="card"><h3>3) Build</h3><p class="muted">Clusters, pipelines, monitoring and alerting instrumented with SLOs from day one.</p></div>
          <div class="card"><h3>4) Operate</h3><p class="muted">SRE support, finops reviews, incident drills and proactive reliability improvements.</p></div>
        </div>
      </div>
    </section>

    <section id="testimonials">
      <div class="container">
        <h2 class="section-title">What clients say</h2>
        <div class="grid grid-3">
          <figure class="card"><blockquote>“CloudInfraFlow gave us a production‑ready AKS with GitOps in <strong>3 weeks</strong>. Our deployment frequency tripled.”</blockquote><figcaption class="muted">CTO, FinTech</figcaption></figure>
          <figure class="card"><blockquote>“They cut our AWS bill by <strong>41%</strong> without hurting performance. Clean dashboards, clean handover.”</blockquote><figcaption class="muted">Head of Engineering, SaaS</figcaption></figure>
          <figure class="card"><blockquote>“Best SRE playbooks I’ve seen. Incidents are calmer and faster now.”</blockquote><figcaption class="muted">VP Ops, Retail</figcaption></figure>
        </div>
      </div>
    </section>

    <section id="pricing">
      <div class="container">
        <h2 class="section-title">Pricing</h2>
        <div class="grid grid-3">
          <div class="card"><h3>Starter</h3><p class="muted">Best for MVPs</p><div class="price">$999</div><p class="note">Landing zone + CI/CD + monitoring</p></div>
          <div class="card" style="outline:2px solid rgba(0,255,169,.3)"><h3>Growth</h3><p class="muted">Scale with confidence</p><div class="price">$2,999</div><p class="note">Kubernetes + GitOps + SRE</p></div>       
          <div class="card"><h3>Enterprise</h3><p class="muted">Custom compliance</p><div class="price">Custom</div><p class="note">Blueprints, controls, audits</p></div>
        </div>
        <p class="note" style="margin-top:12px">Transparent, fixed‑scope packages. Need something else? <a href="#contact" class="btn" style="margin-left:8px">Ask for a custom quote</a></p>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq">
      <div class="container">
        <h2 class="section-title">FAQ</h2>
        <details>
          <summary>Do you support multi‑cloud?</summary>
          <p class="muted">Yes. We work across AWS, Azure, and GCP, and design for portability where it makes sense.</p>
        </details>
        <details>
          <summary>How fast can we start?</summary>
          <p class="muted">We usually begin with a free 45‑minute architecture review within 24 hours, followed by a short Statement of Work.</p>
        </details>
        <details>
          <summary>Will you work with our current team?</summary>
          <p class="muted">Absolutely. We pair with your developers and ops to upskill while delivering.</p>
        </details>
      </div>
    </section>

    <!-- About section with your image placed in the lower part of the page -->
    <section id="about">
      <div class="container">
        <h2 class="section-title">About</h2>
        <div class="grid grid-2">
          <div class="profile-card">
            <div class="avatar-ring">
              <picture>
                <source type="image/webp" srcset="assets/img/smruti_768.webp 768w, assets/img/smruti_512.webp 512w, assets/img/smruti_384.webp 384w" sizes="(max-width: 900px) 90vw, 480px">
                <img class="avatar" src="assets/img/smruti.jpg" alt="Smruti Subhrajyoti Behera — Cloud/DevOps Engineer" loading="eager" decoding="async" />
              </picture>
              <div class="avatar-overlay"></div>
            </div>
            <div class="profile-meta">
              <span>Smruti Subhrajyoti Behera</span>
              <span class="pill">Cloud • DevOps • SRE</span>
            </div>
          </div>
          <div class="card">
            <h3>Who we are</h3>
            <p class="muted">We’re platform engineers who’ve shipped systems for regulated finance, B2B SaaS and high‑traffic retail. Our style is practical: ship working infrastructure, document it, and leave your team stronger than before.</p>
            <ul class="muted">
              <li>✔ 20+ clusters deployed (EKS/AKS/GKE)</li>
              <li>✔ 30–50% cost savings typical with FinOps reviews</li>
              <li>✔ SLOs and on‑call baked in from day one</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="contact">
      <div class="container">
        <h2 class="section-title">Let’s talk</h2>
        <p class="muted">Tell us about your goals. We’ll reply with a free architecture outline within 24 hours.</p>
        <form class="card" onsubmit="return sendMail(event)">
          <div class="grid grid-2" style="gap:12px">
            <label> Name<input id="name" required placeholder="Your name" style="width:100%"/></label>
            <label> Email<input id="email" type="email" required placeholder="you@company.com" style="width:100%"/></label>
          </div>
          <label style="display:block;margin-top:12px"> Message<textarea id="msg" required placeholder="What are you building?" style="width:100%;min-height:120px"></textarea></label>
          <div class="cta"><button class="btn btn-primary" type="submit">Send Message</button><span class="muted" id="status" role="status" aria-live="polite"></span></div>
        </form>
        <div class="sticky-cta">
          <a href="#contact" class="btn btn-primary" style="width:100%">Start your free review</a>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <div class="divider"></div>
      <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;align-items:center">
        <div class="muted">© <span id="year"></span> CloudInfraFlow. All rights reserved.</div>
        <div class="muted">hello@cloudinfraflow.com • Gurugram, IN</div>
        <div>
          <a class="btn" href="#home" aria-label="Back to top">Top ↑</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Structured data -->
  <script type="application/ld+json">{
    "@context":"https://schema.org",
    "@type":"Organization",
    "name":"CloudInfraFlow",
    "url":"https://cloudinfraflow.com",
    "logo":"https://cloudinfraflow.com/favicon.svg",
    "sameAs":[],
    "description":"Cloud infrastructure, DevOps, Kubernetes, CI/CD, SRE, and FinOps services across AWS, Azure, and GCP.",
    "areaServed":["IN","US","EU"],
    "contactPoint":[{"@type":"ContactPoint","contactType":"sales","email":"hello@cloudinfraflow.com"}]
  }</script>

  <script>
    const toggleNav = () => {
      const ul = document.querySelector('nav ul');
      const isOpen = getComputedStyle(ul).display !== 'none';
      if (isOpen) {
        ul.style.display = 'none';
      } else {
        ul.style.display = 'flex';
        ul.style.flexDirection = 'column';
        ul.style.gap = '8px';
        ul.style.padding = '12px 0';
      }
    };
    document.getElementById('year').textContent = new Date().getFullYear();

    // Accessible mailto handler (fixes missing function and prevents errors)
    function sendMail(e){
      e.preventDefault();
      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const msg = document.getElementById('msg').value.trim();
      if(!name || !email || !msg){
        document.getElementById('status').textContent = 'Please fill in all fields.';
        return false;
      }
      const subject = `New inquiry from ${name}`;
      const body = `${msg}%0D%0A%0D%0AFrom: ${name} <${email}>`;
      const mailto = `mailto:hello@cloudinfraflow.com?subject=${encodeURIComponent(subject)}&body=${body}`;
      document.getElementById('status').textContent = 'Opening your email client…';
      window.location.href = mailto;
      return false;
    }

    // Reveal-on-scroll animation
    const revealEls = document.querySelectorAll('.card, .section-title, .headline, .sub');
    const io = new IntersectionObserver((entries)=>{
      entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('fade-up'); io.unobserve(e.target);} });
    }, {threshold: 0.1});
    revealEls.forEach(el=> io.observe(el));
  </script>
</body>
</html>

